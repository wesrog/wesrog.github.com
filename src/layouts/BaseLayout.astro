---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PersistentPlayer from '../components/PersistentPlayer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}
const { title, description = 'Thoughts and waves from Wes Rogers.', noindex = false } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title === 'WR' ? 'WR' : `${title} | WR`}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="WR" href="/rss.xml" />
    <ClientRouter />
  </head>
  <body>
  <script>
    import type { TransitionBeforePreparationEvent } from 'astro:transitions/client';

    // Native View Transitions can capture the new-page screenshot before Astro's scrollTo() fires, leaving the page at 0.
    let savedScrollY: number | null = null;

    document.addEventListener('astro:before-preparation', (e: Event) => {
      const event = e as TransitionBeforePreparationEvent;
      if (event.navigationType === 'traverse') {
        savedScrollY = (history.state?.scrollY as number) ?? 0;
      }
    });

    document.addEventListener('astro:after-swap', () => {
      if (savedScrollY !== null) {
        window.scrollTo({ top: savedScrollY, behavior: 'instant' });
      }
    });

    document.addEventListener('astro:page-load', () => {
      if (savedScrollY !== null) {
        window.scrollTo({ top: savedScrollY, behavior: 'instant' });
        savedScrollY = null;
      }
    });
  </script>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <PersistentPlayer />
  </body>
</html>
