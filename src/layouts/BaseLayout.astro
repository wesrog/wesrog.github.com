---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PersistentPlayer from '../components/PersistentPlayer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}
const { title, description = 'Thoughts and waves from Wes Rogers.', noindex = false } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title === 'WR' ? 'WR' : `${title} | WR`}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="WR" href="/rss.xml" />
    <ClientRouter />
  </head>
  <body>
  <script>
    import type { TransitionBeforePreparationEvent, TransitionBeforeSwapEvent } from 'astro:transitions/client';

    // Astro's ClientRouter stores scroll in history.state, but the native View Transitions
    // API can capture the new-page screenshot before scrollTo() takes effect. This uses
    // sessionStorage as an independent save/restore layer so back-nav restores correctly.

    const scrollKey = (href: string) => `scroll:${new URL(href).pathname}`;
    let pendingScrollY: number | null = null;
    let isNavigating = false;
    let scrollTimer: ReturnType<typeof setTimeout> | undefined;

    function saveScroll(href: string) {
      try { sessionStorage.setItem(scrollKey(href), String(window.scrollY)); } catch {}
    }
    function getSavedScroll(href: string): number | null {
      try { const v = sessionStorage.getItem(scrollKey(href)); return v !== null ? Number(v) : null; } catch { return null; }
    }

    // Debounced scroll tracking — this module runs once, no duplicate listeners.
    window.addEventListener('scroll', () => {
      if (isNavigating) return;
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(() => saveScroll(location.href), 100);
    }, { passive: true });

    document.addEventListener('astro:before-preparation', (e: Event) => {
      const event = e as TransitionBeforePreparationEvent;
      isNavigating = true;
      // Use event.from (not location.href) — for traversals popstate has already changed location.
      saveScroll(event.from.href);
      pendingScrollY = event.navigationType === 'traverse'
        ? getSavedScroll(event.to.href)
        : null;
    });

    document.addEventListener('astro:before-swap', (e: Event) => {
      if (pendingScrollY === null) return;
      const scrollY = pendingScrollY;
      // Restore after the VT animation completes in case the animation overrides scroll.
      (e as TransitionBeforeSwapEvent).viewTransition.finished
        .then(() => requestAnimationFrame(() => window.scrollTo({ top: scrollY, behavior: 'instant' })))
        .catch(() => {});
    });

    document.addEventListener('astro:after-swap', () => {
      if (pendingScrollY !== null) window.scrollTo({ top: pendingScrollY, behavior: 'instant' });
    });

    document.addEventListener('astro:page-load', () => {
      if (pendingScrollY !== null) {
        window.scrollTo({ top: pendingScrollY, behavior: 'instant' });
        pendingScrollY = null;
      }
      isNavigating = false;
    });
  </script>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <PersistentPlayer />
  </body>
</html>
