---
import type { ImageMetadata } from 'astro';

type ImageInput =
  | string
  | ImageMetadata
  | { src: string | ImageMetadata; caption?: string };

interface Props {
  images: ImageInput[];
}

const { images } = Astro.props;

type Entry = { src: string; caption?: string };

const entries: Entry[] = images.map(img => {
  if (typeof img === 'string') return { src: img };
  if ('width' in img) return { src: (img as ImageMetadata).src };
  const obj = img as { src: string | ImageMetadata; caption?: string };
  const src = typeof obj.src === 'string' ? obj.src : (obj.src as ImageMetadata).src;
  return { src, caption: obj.caption };
});

const uid = Math.random().toString(36).slice(2, 8);
---
<div class="gallery" data-uid={uid}>
  {entries.map(({ src, caption }, i) => (
    <button class="gallery-btn" data-src={src} data-caption={caption ?? ''} data-index={i}>
      <img src={src} loading="lazy" alt={caption ?? ''} />
      {caption && <span class="gallery-caption">{caption}</span>}
    </button>
  ))}
</div>
<dialog class="lightbox" id={`lb-${uid}`}>
  <img src="" alt="" />
  <p class="lb-caption"></p>
  <button class="lb-prev" aria-label="Previous">&#8249;</button>
  <button class="lb-next" aria-label="Next">&#8250;</button>
</dialog>

<script>
  document.querySelectorAll<HTMLElement>('.gallery').forEach(gallery => {
    const uid = gallery.dataset.uid!;
    const dialog = document.getElementById(`lb-${uid}`) as HTMLDialogElement;
    const lbImg = dialog.querySelector('img') as HTMLImageElement;
    const lbCaption = dialog.querySelector('.lb-caption') as HTMLParagraphElement;
    const prevBtn = dialog.querySelector('.lb-prev') as HTMLButtonElement;
    const nextBtn = dialog.querySelector('.lb-next') as HTMLButtonElement;

    const btns = Array.from(gallery.querySelectorAll<HTMLElement>('.gallery-btn'));
    const srcs = btns.map(b => b.dataset.src!);
    const captions = btns.map(b => b.dataset.caption ?? '');
    let current = 0;

    function show(index: number) {
      current = (index + srcs.length) % srcs.length;
      lbImg.src = srcs[current];
      lbImg.alt = captions[current];
      lbCaption.textContent = captions[current];
      lbCaption.style.display = captions[current] ? '' : 'none';
      if (!dialog.open) dialog.showModal();
    }

    btns.forEach((btn, i) => btn.addEventListener('click', () => show(i)));

    prevBtn.addEventListener('click', e => { e.stopPropagation(); show(current - 1); });
    nextBtn.addEventListener('click', e => { e.stopPropagation(); show(current + 1); });

    dialog.addEventListener('click', e => { if (e.target === dialog) dialog.close(); });

    dialog.addEventListener('keydown', e => {
      if (e.key === 'ArrowRight') show(current + 1);
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'Escape') dialog.close();
    });
  });
</script>

<style>
.gallery {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 0.5em;
  margin: 1em 0;
}

.gallery-btn {
  position: relative;
  padding: 0;
  margin: 0;
  border: none;
  cursor: pointer;
  background: none;
  overflow: hidden;
  display: block;
}

.gallery-btn img {
  width: 100%;
  height: 180px;
  object-fit: cover;
  display: block;
  transition: opacity 0.15s;
}

.gallery-btn:hover img { opacity: 0.85; }

.gallery-caption {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.65));
  color: #fff;
  font-size: 0.72em;
  padding: 1.5em 0.5em 0.4em;
  line-height: 1.3;
  text-align: left;
}

/* lightbox */
.lightbox {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  max-width: 100vw;
  max-height: 100vh;
  padding: 0;
  border: none;
  background: transparent;
  overflow: visible;
}

.lightbox::backdrop {
  background: rgba(0, 0, 0, 0.85);
}

.lightbox > img {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  max-width: 90vw;
  max-height: 85vh;
  object-fit: contain;
  display: block;
}

.lb-caption {
  position: absolute;
  bottom: 1.5em;
  left: 50%;
  transform: translateX(-50%);
  color: #fff;
  font-size: 0.85em;
  text-align: center;
  margin: 0;
  padding: 0 1em;
  opacity: 0.85;
  width: max-content;
  max-width: 80vw;
}

.lb-prev,
.lb-next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  color: rgba(255, 255, 255, 0.75);
  font-size: 3em;
  cursor: pointer;
  padding: 0.1em 0.3em;
  line-height: 1;
  transition: color 0.15s;
  user-select: none;
}

.lb-prev { left: 0.25em; }
.lb-next { right: 0.25em; }
.lb-prev:hover,
.lb-next:hover { color: #fff; }
</style>
