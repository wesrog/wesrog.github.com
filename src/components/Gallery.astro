---
import type { ImageMetadata } from 'astro';

interface ImageEntry {
  src: ImageMetadata | string;
  caption?: string;
}
interface Props {
  images: (ImageMetadata | string | ImageEntry)[];
}
const { images } = Astro.props;
const uid = Math.random().toString(36).slice(2, 8);

function normalize(img: ImageMetadata | string | ImageEntry): { src: string; caption?: string } {
  if (typeof img === 'string') return { src: img };
  if ('width' in img) return { src: (img as ImageMetadata).src };
  const entry = img as ImageEntry;
  const src = typeof entry.src === 'string' ? entry.src : (entry.src as ImageMetadata).src;
  return { src, caption: entry.caption };
}

const normalized = images.map(normalize);
---
<div class="gallery" data-uid={uid}>
  {normalized.map((img, i) => (
    <figure class="gallery-item" data-src={img.src} data-caption={img.caption ?? ''} data-index={i}>
      <img src={img.src} loading="lazy" alt={img.caption ?? ''} />
      {img.caption && <figcaption>{img.caption}</figcaption>}
    </figure>
  ))}
</div>
<dialog class="lightbox" id={`lb-${uid}`}>
  <img src="" alt="" />
  <p class="caption"></p>
</dialog>

<script>
  document.querySelectorAll<HTMLElement>('.gallery').forEach(gallery => {
    const uid = gallery.dataset.uid!;
    const dialog = document.getElementById(`lb-${uid}`) as HTMLDialogElement;
    const lightboxImg = dialog.querySelector('img') as HTMLImageElement;
    const captionEl = dialog.querySelector('.caption') as HTMLParagraphElement;

    const btns = Array.from(gallery.querySelectorAll<HTMLElement>('.gallery-item'));
    let currentIndex = 0;

    function openAt(index: number) {
      currentIndex = index;
      const btn = btns[index];
      lightboxImg.src = btn.dataset.src!;
      const caption = btn.dataset.caption ?? '';
      captionEl.textContent = caption;
      captionEl.style.display = caption ? '' : 'none';
      if (!dialog.open) dialog.showModal();
    }

    btns.forEach((btn, i) => {
      btn.addEventListener('click', () => openAt(i));
    });

    dialog.addEventListener('click', e => {
      if (e.target === dialog) dialog.close();
    });

    dialog.addEventListener('keydown', e => {
      if (e.key === 'ArrowRight') openAt((currentIndex + 1) % btns.length);
      if (e.key === 'ArrowLeft') openAt((currentIndex - 1 + btns.length) % btns.length);
    });
  });
</script>

<style>
.gallery {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 0.5em;
  margin: 1em 0;
}
.gallery-item {
  padding: 0;
  margin: 0;
  border: none;
  cursor: pointer;
  background: none;
  overflow: hidden;
}
.gallery-item img {
  width: 100%;
  height: 180px;
  object-fit: cover;
  display: block;
  transition: opacity 0.15s;
}
.gallery-item:hover img { opacity: 0.85; }
.gallery-item figcaption {
  font-size: 0.8em;
  color: var(--color-muted);
  padding: 0.35em 0.25em 0;
  line-height: 1.3;
}
.lightbox {
  max-width: 92vw;
  max-height: 92vh;
  padding: 0;
  border: none;
  background: transparent;
}
.lightbox img {
  max-width: 92vw;
  max-height: calc(92vh - 3em);
  object-fit: contain;
  display: block;
}
.caption {
  color: #fff;
  font-size: 0.85em;
  text-align: center;
  padding: 0.5em 1em;
  margin: 0;
}
.lightbox::backdrop { background: var(--color-overlay); }
</style>
